{
  // Generic-конфиг ДВИЖКА (шаблон). Сам движок НЕ деплоится — деплоит проект-пак, который
  // потребляет движок и держит СВОЙ wrangler.jsonc с реальными id/именами ресурсов.
  // Здесь — плейсхолдеры (для wrangler types / локального dev форка). Подставь свои id.
  "name": "telegram-chat-bot",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-31",
  "observability": { "enabled": true },
  "vars": {
    "OPENROUTER_HOST": "https://openrouter.ai/api/v1",
    "OPENROUTER_MODEL": "openrouter/free",
    "ENABLE_REASONING": "true",
    "ENABLE_VISION": "false",
    "MAX_HISTORY_CHARS": "8000",
    "MAX_TOKENS": "4000",
    "ANSWER_PROB": "0.1"
  },
  "kv_namespaces": [
    { "binding": "KV", "id": "REPLACE_WITH_YOUR_KV_ID" }
  ],
  "d1_databases": [
    { "binding": "DB", "database_name": "telegram-chat-bot-db", "database_id": "REPLACE_WITH_YOUR_D1_ID" }
  ],
  "ai": { "binding": "AI" },
  "vectorize": [
    { "binding": "VECTORIZE", "index_name": "telegram-chat-bot-memory" }
  ],
  "triggers": {
    "crons": ["0 5 * * *", "0 6 * * *"]
  }
}
